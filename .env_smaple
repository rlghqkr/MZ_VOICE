# MZ-VOICE 환경 설정

# OpenAI API 키 (필수)
OPENAI_API_KEY="Your OpenAI API Key Here"

# 임베딩 모델
EMBEDDING_MODEL=text-embedding-3-small

# LLM 모델
LLM_MODEL=gpt-4o

# ChromaDB 설정
CHROMA_PERSIST_DIR=./data/chroma_db
CHROMA_COLLECTION_NAME=youth_policy_docs

# 법령 ChromaDB 설정
CHROMA_LAW_PERSIST_DIR=./data/chroma_db_law
CHROMA_LAW_COLLECTION_NAME=laws

# STT 설정
# STT_PROVIDER=whisper
# WHISPER_MODEL_SIZE=base
STT_PROVIDER=sensevoice
ASR_API_BASE_URL=http://34.130.232.40:8000 # Example URL
ASR_INCLUDE_EMOTION=true
ASR_TIMEOUT_SECONDS=30
ASR_USE_EMOTION=true
STT_LLM_CORRECTION=true
STT_LLM_MODEL=gpt-5.2
STT_LLM_MAX_TOKENS=1000

# TTS 설정
TTS_PROVIDER=gtts

# SMTP 메일 설정 (선택)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# 서버 설정
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=9000
DEBUG=true

# Reranking 끄기
ENABLE_RERANKING=true

# 프롬프트 로깅
ENABLE_PROMPT_LOGGING=true
